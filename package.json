{
  "name": "@courthive/provider-config",
  "packageManager": "pnpm@11.0.8",
  "version": "0.1.0",
  "description": "Canonical types, KEYS, validators, computeEffectiveConfig, and MUTATION_PERMISSIONS for CourtHive provider configuration.",
  "author": "Charles Allen <charles@CourtHive.com> (CourtHive.com)",
  "license": "MIT",
  "private": false,
  "bugs": {
    "url": "https://github.com/CourtHive/provider-config/issues",
    "email": "support@CourtHive.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CourtHive/provider-config.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "check-types": "tsc --noEmit",
    "test": "vitest --run",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write \"src/**/*.ts\"",
    "commitlint": "commitlint --edit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --cache --fix",
    "*": "prettier --ignore-unknown --write"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
